{
  "name": "playwright-template-typescript",
  "version": "1.0.0",
  "description": "End-to-end testing framework with Playwright, TypeScript, Page Object Model, and dual reporting",
  "scripts": {
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:report": "npx playwright show-report reports",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "keywords": ["playwright", "typescript", "e2e", "testing", "pom"],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "allure": "^3.13.2",
    "dotenv": "^17.4.2"
  }
}
